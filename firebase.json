{
  "hosting": {
    "target": "vehicle-app",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/extractRcData",
        "function": "extractRc",
        "region": "us-central1"
      },
      {
        "source": "/api/razorpay/createOrder",
        "function": "createRazorpayOrder",
        "region": "us-central1"
      },
      {
        "source": "/api/razorpay/verifyPayment",
        "function": "verifyRazorpayPayment",
        "region": "us-central1"
      },
      {
        "source": "/api/credits/me",
        "function": "getMyCredits",
        "region": "us-central1"
      },
      {
        "source": "/api/credits/history",
        "function": "getCreditHistory",
        "region": "us-central1"
      },
      {
        "source": "/api/credits/consume",
        "function": "consumeCredits",
        "region": "us-central1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
