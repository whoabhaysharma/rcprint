# Required for extractRc and batch AI (emulator or production). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key"

# --- Razorpay test keys (used only when the Functions emulator runs: FUNCTIONS_EMULATOR=true) ---
# Copy this file to .env and paste your Dashboard test keys. Production ignores these.
RAZORPAY_TEST_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_TEST_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Razorpay live keys (production deploy + optional local runs outside the emulator) ---
# Set these in production via `firebase functions:config:set` (razorpay.key_id / key_secret) or Secrets.
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Optional: credits per successful AI extraction (default: 2).
# AI_PROCESSING_CREDIT_COST=2

# Abuse / cost controls (HTTPS extract + batch workers)
# EXTRACT_RC_MAX_BASE64_CHARS=14000000
# EXTRACT_RC_RATE_WINDOW_MS=60000
# EXTRACT_RC_RATE_LIMIT_MAX=24
# BATCH_AI_DEBIT_WINDOW_MS=3600000
# BATCH_AI_DEBIT_MAX=200
# MAX_BATCH_PDF_BYTES=12582912

# Super admin bootstrap: set one email, then call POST/GET /api/init (public). It will make that email's Firebase user the first super admin.
# Grant credits (requires Bearer token for that super admin): GET /api/admin/grantCredits?email=user@example.com&credits=100
# SUPER_ADMIN_EMAIL="admin@yourdomain.com"
# ADMIN_GRANT_MAX_PER_CALL=50000
